
### attribute ##################################################################

grp_width: <integer>                    # Column width of group (default: 48)
wns_width: <integer>                    # Column width of WNS   (default: 12) 
tns_width: <integer>                    # Column width of TNS   (default: 12)
nvp_width: <integer>                    # Column width of NVP   (default:  6)

# The column width of the group will resized automatically according to the 
# content if "grp_width" isn't defined. If the width is smaller than 48, use
# 48 as the column width.

clean_sign_enable: <boolean>            # Enable clean signature (default: false, only for compare mode)
clean_sign:        <string>             # Define clean signature (default: ***)

# When set "clean_sign_enable" true, use the clean sign to replace the print 
# value of the wns/tns/nvp if the violation clean.

### path_operation #############################################################

#--- Path choose format:

[#]<type>:<group>:<path>

  type      Violation type.
  group     Violation group (use "*" to select all groups).
  path      Regular expression for path specify.

# Use "#" as the first char of the <path> to ignore the command. 

#--- Operation command:

<path>: {cmd1: set1, cmd2: set2, ...}

  [#]u:[condition]:<ugroup>     # Move the path to the user-defined group if the condition match

    condition   format: <target><operation><value>
                    target:    req/act/slk          # required/actual/slack     
                    operation: [>, <, ==, >=, <=]
                    value:     <float>
    ugroup      Name of the user-defined group.

# 1. Use "#" as the first char of the <path> to ignore the command. 
# 2. Always match if the condition undefined.

### group_operation ############################################################

#--- Group choose format:

[#]<type>:<group>

  type      Violation type.
  group     Regular expression for group specify.

#--- Operation command:

<group>: {cmd1: set1, cmd2: set2, ...}

  [#]t:[condition]:<tag>            # Add a group tag
  [#]s:[condition]:<status>         # Add a group status (one-char tag)
  [#]m:[condition]:<identifier>     # Import a group comment by the identifier
  [#]c:[condition]:<class_title>    # Classify groups by the user-defined title

    condition   format: <target><operation><value>
                    target:    wns/tns/nvp     
                    operation: [>, <, ==, >=, <=]
                    value:     <float>
    status      One-char tag at line start.
    message     Comment at line end.

# 1. Use "#" as the first char of the <path> to ignore the command. 
# 2. Always match if the condition undefined.
# 3. The condition only supports the single mode or the new report in the compare mode.

  [#]r:<pat>:<repl>                 # Replace the group name by the regular expression

    pat         Regular expression match pattern.
    rep         Regular expression replace pattern.

### violate operation ##########################################################

#--- Violation choose format:

[#]<type>

  type      Violation type (give the default rule for all violations by set 'default')

#--- Operation command:

<type>: {cmd1: set1, cmd2: set2, ...}

  [#]go:<rid>:<target>:<order>      # Reorder the print order of groups in each violation

    rid         Report select   
                    single mode: [s]
                    multi mode:  [l, r, d]  # l: left, r: right, d: difference
    target      wns/tns/nvp
    order       inc/dec         (increase/decrease)

  [#]gh:<list>                      # Hide groups by the group list in each violation (repeatable)
  [#]co:<list>                      # Rorder the print order of class in each violation (repeatable)

    list        Group/Class list (ex. v:max_delay/setup:class_a,class_b,class_c)

### Message Define #############################################################

m:<identifier>:<content>

