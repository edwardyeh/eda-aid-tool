
### Atrribute ##################################################################

grp_width: <int>                        # Column width of group (default: 48)
wns_width: <int>                        # Column width of WNS   (default: 12) 
tns_width: <int>                        # Column width of TNS   (default: 12)
nvp_width: <int>                        # Column width of NVP   (default:  6)

PS. "grp_width" will auto resizing if the attribute undefined. 

clean_sign_enable: <true|false>         # Enable clean signature (default: false, for compare mode)
clean_sign:        <string>             # Define clean signature (default: ***)

### Path Choose from the Violation Report ######################################

p:<type>:<group>:<path>                 # Use the regular expression to choose paths

    type        Violation type
    group       Violation group
    path        Regular expression for path specify

### Path Operation #############################################################

<path> u:[condition]:<ugroup>           # Move the path to the user-defined group if the condition match

    condition   format: <target><operation><value>
                    target:    req/act/slk          # required/actual/slack     
                    operation: [>, <, ==, >=, <=]
                    value:     <float>
    ugroup      Name of the user-defined group

    PS: Always match if the condition undefined.

### Group Choose from the Summary Report #######################################

g:<type>:<group>                        # Use the regular expression to choose groups

    type        Violation type
    group       Regular expression for group specify

### Group Opteraion ############################################################

<group> t:[condition]:<tag>             # Add a group tag
<group> s:[condition]:<status>          # Add a group status (one-char tag)
<group> m:[condition]:<identifier>      # Import a group comment by the identifier
<group> c:[condition]:<class_title>     # Classify groups by the user-defined title

    condition   format: <target><operation><value>
                    target:    wns/tns/nvp     
                    operation: [>, <, ==, >=, <=]
                    value:     <float>
    status      One-char tag at line start
    message     Comment at line end

    PS: 1. The condition only supports the single mode or the new report in the compare mode.
        2. Always match if the condition undefined.

<group> r:<pat>:<repl>                  # Replace the group name by the regular expression

    pat         Regular expression match pattern
    rep         Regular expression replace pattern

### Group Sorting ##############################################################

v:<type>:<rid>:<target>:<order>

    type        violation type  (set 'default' for the default rule)



    rid         report select   
                    single mode: [s]
                    multi mode:  [l, r, d]  # l:left, r:right, d:difference
    target      wns/tns/nvp
    order       inc/dec         (increase/decrease)

### Message Define #############################################################

m:<identifier>:<content>

